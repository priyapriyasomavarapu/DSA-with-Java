Easy Level
1. Prime Number
int n=13;
boolean prime=true;

for(int i=2;i<=n/2;i++){
    if(n%i==0){
        prime=false;
        break;
    }
}
2. Fibonacci Series
int a=0,b=1;

for(int i=1;i<=10;i++){
    System.out.print(a+" ");

    int c=a+b;
    a=b;
    b=c;
}
3. Factorial
int fact=1;

for(int i=1;i<=n;i++){
    fact*=i;
}
4. Armstrong Number
Example: 153

int num=153;
int temp=num;
int sum=0;

while(temp>0){
    int rem=temp%10;
    sum=sum+rem*rem*rem;
    temp/=10;
}
